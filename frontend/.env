# Modo REAL (default do build/imagem) — frontend fala com o backend de verdade.
# - Gateway via port-forward:  kubectl port-forward svc/api-gateway 9000:9000
# - Keycloak via hosts-alias:  '127.0.0.1 keycloak' no hosts + port-forward svc/keycloak 8080:8080
#   (assim browser e cluster veem o MESMO issuer http://keycloak:8080 — sem tocar no backend).
# Para a vitrine offline (mock), use .env.demo → copie para .env.local (que sobrepõe e é git-ignored).
VITE_API_GATEWAY_URL=http://localhost:9000
VITE_KEYCLOAK_URL=http://keycloak:8080
VITE_KEYCLOAK_REALM=hospital
VITE_KEYCLOAK_CLIENT_ID=hospital-frontend
VITE_DEMO_MODE=false
