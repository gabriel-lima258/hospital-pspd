# Modo REAL (default do build/imagem) — frontend fala com o backend de verdade.
# - Gateway  via port-forward: kubectl port-forward svc/api-gateway 9000:9000
# - Keycloak via port-forward: kubectl port-forward svc/keycloak    8080:8080
# Split-horizon: o browser usa localhost:8080 (sem editar hosts); o gateway valida esse issuer mas
# busca as chaves no Service interno keycloak:8080 (ver k8s/base/api-gateway.yaml, RUNBOOK-frontend).
# Para a vitrine offline (mock), use .env.demo → copie para .env.local (sobrepõe e é git-ignored).
VITE_API_GATEWAY_URL=http://localhost:9000
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=hospital
VITE_KEYCLOAK_CLIENT_ID=hospital-frontend
VITE_DEMO_MODE=false
